# Ollama Configuration
# Recommended models for German legal text:
# - LLM: llama3:8b, qwen2.5:7b, or gemma2:9b
# - Embeddings: mxbai-embed-large or bge-m3
OLLAMA_MODEL=llama3:8b
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text-v2-moe

# Cloud LLM Configuration (if using a cloud provider)
GEMINI_API_KEY=

# Database Configuration
VECTOR_DB_PATH=./vector_db
COLLECTION_NAME=bgb_all
CHROMA_TELEMETRY_ENABLED=false

# Scraping Configuration
BGB_URL=https://www.gesetze-im-internet.de/bgb/BJNR001950896.html

# RAG Configuration
# Chunk size adjusted for embedding model limits (most models: ~512 token max)
# 1 token ≈ 4 characters for German, so 512 tokens ≈ 2000 characters
CHUNK_SIZE=1600
CHUNK_OVERLAP=200
TOP_K_RESULTS=10
